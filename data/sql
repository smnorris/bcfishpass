GRANT ALL ON TABLE wcrp_bela_atna_necl.combined_tracking_table_crossings_wcrp_vw TO cwf_analyst;
GRANT ALL ON TABLE wcrp_bela_atna_necl.combined_tracking_table_crossings_wcrp_vw TO cwf_tech;
GRANT ALL ON TABLE wcrp_bela_atna_necl.combined_tracking_table_crossings_wcrp_vw TO cwf_user;
